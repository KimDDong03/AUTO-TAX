{
  "name": "auto-tax",
  "version": "0.1.0",
  "description": "KEPCO solar tax invoice automation web app",
  "author": "AUTO-TAX",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/src/main.ts",
    "dev:web": "wait-on tcp:127.0.0.1:4300 && vite --config web/vite.config.ts",
    "dev:vercel": "vercel dev",
    "renewal-agent:dev": "tsx scripts/renewal-agent.ts",
    "renewal-helper:dev": "tsx scripts/renewal-local-helper.ts",
    "renewal-helper:start": "powershell -ExecutionPolicy Bypass -File scripts/start-renewal-local-helper.ps1 -Detached",
    "renewal-helper:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-renewal-local-helper.ps1",
    "renewal-helper:status": "powershell -ExecutionPolicy Bypass -File scripts/status-renewal-local-helper.ps1",
    "renewal-helper:install": "powershell -ExecutionPolicy Bypass -File scripts/install-renewal-local-helper-autostart.ps1 -StartNow",
    "renewal-helper:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-renewal-local-helper-autostart.ps1",
    "renewal-helper:package": "node scripts/build-renewal-local-helper-package.mjs",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "build:web:vercel": "vite build --config web/vite.config.ts --outDir ../public",
    "build:vercel": "npm run build:web:vercel",
    "start": "node dist/server/main.js",
    "check": "tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit && tsc -p tsconfig.vercel.json --noEmit",
    "test:server": "node --import tsx --test server/src/**/*.test.ts",
    "test:e2e:smoke": "node --env-file=.env scripts/e2e-smoke.mjs",
    "rebuild:node": "node scripts/fix-popbill-package.mjs",
    "postinstall": "node scripts/fix-popbill-package.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "imapflow": "^1.2.16",
    "mailparser": "^3.9.0",
    "nodemailer": "^7.0.7",
    "popbill": "^1.63.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.5"
  }
}
