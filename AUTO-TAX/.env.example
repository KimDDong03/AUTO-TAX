# Runtime
PORT=4300

# Supabase Web
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
VITE_SUPABASE_ANON_KEY=

# Supabase Server
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ORGANIZATION_ID=
AUTO_TAX_ORGANIZATION_NAME=
AUTO_TAX_ORGANIZATION_BUSINESS_NUMBER=

# Supabase CLI
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Mail IMAP
AUTO_TAX_IMAP_HOST=imap.gmail.com
AUTO_TAX_IMAP_PORT=993
AUTO_TAX_IMAP_SECURE=true
AUTO_TAX_IMAP_USER=your-account@gmail.com
AUTO_TAX_IMAP_PASS=your-gmail-app-password
AUTO_TAX_IMAP_MAILBOX=INBOX

# Mail SMTP
AUTO_TAX_SMTP_HOST=smtp.gmail.com
AUTO_TAX_SMTP_PORT=465
AUTO_TAX_SMTP_SECURE=true
AUTO_TAX_SMTP_USER=your-account@gmail.com
AUTO_TAX_SMTP_PASS=your-gmail-app-password
AUTO_TAX_SMTP_FROM_NAME=AUTO-TAX
AUTO_TAX_SMTP_FROM_EMAIL=your-account@gmail.com
AUTO_TAX_NOTIFICATION_EMAILS=ops1@example.com,ops2@example.com

# Issue Schedule
AUTO_TAX_DEFAULT_ISSUE_DAY=25
AUTO_TAX_DEFAULT_ISSUE_HOUR=14
AUTO_TAX_DEFAULT_ISSUE_MINUTE=0
AUTO_TAX_MAIL_POLL_MINUTES=5
AUTO_TAX_MAIL_SYNC_START_AT=
AUTO_TAX_TIMEZONE=Asia/Seoul
AUTO_TAX_SCHEDULER_ENABLED=true

# Popbill (server only)
AUTO_TAX_POPBILL_LINK_ID=YOUR_LINK_ID
AUTO_TAX_POPBILL_SECRET_KEY=YOUR_SECRET_KEY
AUTO_TAX_POPBILL_IS_TEST=true
AUTO_TAX_POPBILL_PARTNER_CORP_NUM=2904201164
AUTO_TAX_POPBILL_USER_ID_PREFIX=HAE_
AUTO_TAX_POPBILL_SHARED_PASSWORD=COMMON_POPBILL_PASSWORD
AUTO_TAX_OPERATOR_CONTACT_NAME=운영자명
AUTO_TAX_OPERATOR_CONTACT_EMAIL=operator@example.com
AUTO_TAX_OPERATOR_CONTACT_TEL=01012345678

# Renewal Agent Optional
AUTO_TAX_SERVER_URL=http://127.0.0.1:4300
AUTO_TAX_RENEWAL_AGENT_INTERVAL_MS=5000
AUTO_TAX_RENEWAL_AGENT_ID=
AUTO_TAX_RENEWAL_AGENT_ONCE=false
AUTO_TAX_RENEWAL_AGENT_CERT_PASSWORD_FILE=
AUTO_TAX_RENEWAL_AGENT_CERT_PASSWORD=
