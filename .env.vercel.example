# AUTO-TAX Vercel deployment env example
#
# Add these values in Vercel Project Settings > Environment Variables.
# Do not set VERCEL_URL, VERCEL_ENV, or NODE_ENV manually; Vercel provides them.
# Keep real secrets out of git.

# Browser runtime, exposed to the client bundle
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key
VITE_SUPABASE_AUTH_TIMEOUT_MS=5000
VITE_RENEWAL_HELPER_DOWNLOAD_URL=/downloads/renewal-local-helper.zip
# Set only when the browser must call an API origin different from this Vercel app.
# VITE_API_BASE_URL=

# Server runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTO_TAX_ENCRYPTION_KEY=production-high-entropy-key
AUTO_TAX_OPS_EMAILS=operator@example.com
AUTO_TAX_ALLOWED_ORIGINS=https://your-production-domain.example
AUTO_TAX_SERVER_URL=https://your-production-domain.example
AUTO_TAX_JOB_SECRET=production-job-secret
AUTO_TAX_PUBLIC_LOGIN_TIMEOUT_MS=600000
AUTO_TAX_STORE_INIT_TIMEOUT_MS=12000
AUTO_TAX_ALLOW_STORE_INIT_FAILURE=0

# Popbill, server only
AUTO_TAX_POPBILL_LINK_ID=YOUR_LINK_ID
AUTO_TAX_POPBILL_SECRET_KEY=YOUR_SECRET_KEY
AUTO_TAX_POPBILL_IS_TEST=false
AUTO_TAX_POPBILL_PARTNER_CORP_NUM=
AUTO_TAX_POPBILL_USER_ID_PREFIX=AUTO_
AUTO_TAX_POPBILL_SHARED_PASSWORD=production-popbill-shared-password
AUTO_TAX_POPBILL_CONTACT_NAME=AUTO-TAX
AUTO_TAX_POPBILL_CONTACT_TEL=
AUTO_TAX_POPBILL_CONTACT_EMAIL=

# Issue-complete SMS
SMS_PROVIDER=solapi
AUTO_TAX_ISSUE_MESSAGE_SENDER_NUMBER=
AUTO_TAX_ISSUE_MESSAGE_SENDER_NAME=AUTO-TAX
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

# Public signup email verification
# Gmail app-password mode works when both AUTO_TAX_SUPPORT_* values are set.
AUTO_TAX_SUPPORT_TO_EMAIL=
AUTO_TAX_SUPPORT_APP_PASSWORD=
AUTO_TAX_SIGNUP_EMAIL_PROVIDER=
AUTO_TAX_SIGNUP_SMTP_HOST=
AUTO_TAX_SIGNUP_SMTP_PORT=465
AUTO_TAX_SIGNUP_SMTP_SECURE=true
AUTO_TAX_SIGNUP_SMTP_USER=
AUTO_TAX_SIGNUP_SMTP_PASS=
AUTO_TAX_SIGNUP_EMAIL_FROM=
AUTO_TAX_SIGNUP_EMAIL_FROM_NAME=AUTO-TAX

# Renewal helper package and remote renewal agent
AUTO_TAX_RENEWAL_HELPER_ZIP_PATH=dist/renewal-local-helper.zip
AUTO_TAX_RENEWAL_AGENT_SECRET=

# Supabase Edge Function `job-tick` secrets, set in Supabase, not Vercel.
# AUTO_TAX_SERVER_URL should match the deployed Vercel app URL.
# AUTO_TAX_JOB_SECRET should match the Vercel value above.
