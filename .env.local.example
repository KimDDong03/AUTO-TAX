# AUTO-TAX local development env example
#
# For the full local app, copy this file to `.env`.
# The server loads `.env` through dotenv, and Vite also reads `.env`.
# Keep real secrets out of git.

# Required: Supabase browser runtime
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key

# Required: Supabase server runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTO_TAX_ENCRYPTION_KEY=local-development-encryption-key-change-me
AUTO_TAX_OPS_EMAILS=operator@example.com

# Required: internal jobs and local renewal agent
AUTO_TAX_JOB_SECRET=local-job-secret-change-me

# Required: Popbill, server only. Do not omit these; customer IDs/passwords do not fall back to DB defaults.
AUTO_TAX_POPBILL_LINK_ID=YOUR_LINK_ID
AUTO_TAX_POPBILL_SECRET_KEY=YOUR_SECRET_KEY
AUTO_TAX_POPBILL_IS_TEST=true
AUTO_TAX_POPBILL_USER_ID_PREFIX=AUTO_
AUTO_TAX_POPBILL_SHARED_PASSWORD=local-popbill-shared-password
AUTO_TAX_POPBILL_CONTACT_NAME=AUTO-TAX
AUTO_TAX_POPBILL_CONTACT_EMAIL=popbill-notice@example.com
AUTO_TAX_POPBILL_CONTACT_TEL=02-0000-0000

# SMS, optional local test
# Set SMS_PROVIDER=solapi only when you want to send real test messages.
SMS_PROVIDER=
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

# Public signup email verification, optional local test
# If both values are set, signup email verification uses Gmail SMTP.
AUTO_TAX_SUPPORT_TO_EMAIL=
AUTO_TAX_SUPPORT_APP_PASSWORD=

