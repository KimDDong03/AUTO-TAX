# AUTO-TAX local development env example
#
# For the full local app, copy this file to `.env`.
# The server loads `.env` through dotenv, and Vite also reads `.env`.
# Keep real secrets out of git.

# Local app runtime
PORT=4300
VITE_API_BASE_URL=http://127.0.0.1:4300
AUTO_TAX_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
AUTO_TAX_SERVER_URL=http://127.0.0.1:4300
AUTO_TAX_PUBLIC_LOGIN_TIMEOUT_MS=600000
AUTO_TAX_STORE_INIT_TIMEOUT_MS=5000
AUTO_TAX_ALLOW_STORE_INIT_FAILURE=1

# Supabase browser runtime
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key
VITE_SUPABASE_AUTH_TIMEOUT_MS=5000

# Supabase server runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTO_TAX_ENCRYPTION_KEY=local-development-encryption-key-change-me
AUTO_TAX_OPS_EMAILS=operator@example.com

# Local workspace bootstrap override, optional
SUPABASE_ORGANIZATION_ID=
AUTO_TAX_ORGANIZATION_NAME=AUTO-TAX-Local-Workspace

# Internal jobs and local renewal agent
AUTO_TAX_JOB_SECRET=local-job-secret-change-me
AUTO_TAX_RENEWAL_AGENT_SECRET=
AUTO_TAX_RENEWAL_AGENT_ID=local-renewal-agent
AUTO_TAX_RENEWAL_AGENT_INTERVAL_MS=60000
AUTO_TAX_RENEWAL_AGENT_ONCE=0
AUTO_TAX_RENEWAL_AGENT_CERT_PASSWORD=
# AUTO_TAX_RENEWAL_AGENT_CERT_PASSWORD_FILE=C:\path\to\cert-password.txt

# Local renewal helper
AUTO_TAX_RENEWAL_HELPER_PORT=58987
AUTO_TAX_RENEWAL_HELPER_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
VITE_RENEWAL_HELPER_DOWNLOAD_URL=/downloads/renewal-local-helper.zip
AUTO_TAX_RENEWAL_HELPER_ZIP_PATH=dist/renewal-local-helper.zip

# Popbill, server only
AUTO_TAX_POPBILL_LINK_ID=YOUR_LINK_ID
AUTO_TAX_POPBILL_SECRET_KEY=YOUR_SECRET_KEY
AUTO_TAX_POPBILL_IS_TEST=true
AUTO_TAX_POPBILL_PARTNER_CORP_NUM=
AUTO_TAX_POPBILL_USER_ID_PREFIX=AUTO_
AUTO_TAX_POPBILL_SHARED_PASSWORD=local-popbill-shared-password
AUTO_TAX_POPBILL_CONTACT_NAME=AUTO-TAX
AUTO_TAX_POPBILL_CONTACT_TEL=
AUTO_TAX_POPBILL_CONTACT_EMAIL=

# Issue-complete SMS, optional locally
SMS_PROVIDER=
AUTO_TAX_ISSUE_MESSAGE_SENDER_NUMBER=
AUTO_TAX_ISSUE_MESSAGE_SENDER_NAME=AUTO-TAX
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

# Public signup email verification
# Gmail app-password mode works when both AUTO_TAX_SUPPORT_* values are set.
AUTO_TAX_SUPPORT_TO_EMAIL=
AUTO_TAX_SUPPORT_APP_PASSWORD=
AUTO_TAX_SIGNUP_EMAIL_PROVIDER=
AUTO_TAX_SIGNUP_SMTP_HOST=
AUTO_TAX_SIGNUP_SMTP_PORT=465
AUTO_TAX_SIGNUP_SMTP_SECURE=true
AUTO_TAX_SIGNUP_SMTP_USER=
AUTO_TAX_SIGNUP_SMTP_PASS=
AUTO_TAX_SIGNUP_EMAIL_FROM=
AUTO_TAX_SIGNUP_EMAIL_FROM_NAME=AUTO-TAX

# Browser automation helpers, optional
AUTO_TAX_POPBILL_HELPER_BROWSER_CHANNEL=chrome
AUTO_TAX_POPBILL_HELPER_USER_DATA_DIR=
AUTO_TAX_POPBILL_DEBUG_ARTIFACT_DIR=.tmp-popbill-artifacts
AUTO_TAX_SIGNGATE_HELPER_BROWSER_CHANNEL=chrome
AUTO_TAX_SIGNGATE_HELPER_USER_DATA_DIR=

# Local smoke and operations scripts, optional
AUTO_TAX_E2E_BASE_URL=http://127.0.0.1:4300
AUTO_TAX_PUBLIC_BASE_URL=http://127.0.0.1:4173
AUTO_TAX_PUBLIC_SCREENSHOT_DIR=.tmp-public-screenshots
SUPABASE_PROJECT_REF=
AUTO_TAX_OPS_SMOKE_MAX_STALE_CLAIMED=0
AUTO_TAX_OPS_SMOKE_MAX_QUEUED_JOBS=
AUTO_TAX_OPS_SMOKE_MAX_FAILED_JOBS=
SUPABASE_DB_PASSWORD=

# Secret rotation script, optional
AUTO_TAX_OLD_ENCRYPTION_KEY=
AUTO_TAX_NEW_ENCRYPTION_KEY=
